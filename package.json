{
  "name": "nazo-auth-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": ">=24.16.0 <25",
    "npm": ">=11.13.0 <12"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "audit": "npm audit --audit-level=low",
    "test:delivery": "node --experimental-strip-types --test src/lib/accessDelivery.test.ts",
    "test:unit": "vitest run",
    "security:test": "node --test scripts/check-browser-security.test.mjs",
    "security:source": "node scripts/check-browser-security.mjs source",
    "security:dist": "node scripts/check-browser-security.mjs dist",
    "verify:dist": "node scripts/check-production-build.mjs",
    "test": "npm run audit && npm run test:delivery && npm run lint && npm run test:unit && npm run security:test && npm run security:source && npm run build && npm run verify:dist && npm run security:dist",
    "preview": "vite preview"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@marsidev/react-turnstile": "^1.5.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.10"
  }
}
